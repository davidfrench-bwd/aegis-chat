{
  "version": 2,
  "buildCommand": "next build",
  "installCommand": "npm install",
  "devCommand": "next dev",
  "routes": [
    { "src": "/api/health", "dest": "/api/health.js" }
  ],
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "@supabase_url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@supabase_anon_key",
    "NEXTAUTH_SECRET": "@nextauth_secret"
  }
}